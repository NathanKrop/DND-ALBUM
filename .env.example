# Contact form + email capture are wired to Formspree directly in the components.
# Replace the form ID in:
#   src/app/contact/page.tsx  → fetch("https://formspree.io/f/YOUR_FORM_ID")
#   src/components/EmailCapture.tsx → fetch("https://formspree.io/f/YOUR_FORM_ID")
#
# Get a free form ID at https://formspree.io

# Optional: Supabase for subscriber storage
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
