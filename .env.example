# Email Service Configuration
# Choose one of the options in EMAIL_SETUP.md and configure the appropriate variables below

# Formspree (Recommended - no backend needed)
# EMAIL_SERVICE_URL=https://formspree.io/f/YOUR_FORM_ID

# Resend (Transactional email)
# RESEND_API_KEY=your_api_key_here
# RESEND_FROM_EMAIL=noreply@breezydallas.com

# SendGrid
# SENDGRID_API_KEY=your_api_key_here
# SENDGRID_FROM_EMAIL=noreply@breezydallas.com

# Supabase (Store submissions)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_anon_key
